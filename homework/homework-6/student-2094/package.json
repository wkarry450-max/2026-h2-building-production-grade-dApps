{
  "name": "polkadot-testnet-evm-papi-demo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node src/main.js",
    "cross:call": "node src/evm-pvm-cross-call-example.js",
